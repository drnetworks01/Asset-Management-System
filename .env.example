NEXT_PUBLIC_SITE_URL=http://localhost:3010

# Random 32+ char string for sealing the iron-session cookie.
# Generate one with: openssl rand -base64 48
SESSION_PASSWORD=replace-with-32-or-more-char-random-string

# Path to the SQLite database file (relative to project root)
DATABASE_FILE=data/kurikara.db

# Admin seed used by `pnpm db:seed`. Choose a unique 12+ character password.
# SEED_ADMIN_EMAIL=admin@kurikaralanka.local
# SEED_ADMIN_PASSWORD=

# AI features (Tier 4) — uses OpenRouter to call Anthropic Claude
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-haiku-4.5
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
